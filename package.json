{
  "name": "earth-online-journal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "vite --host 127.0.0.1 --base=/Earth-Online-Journal/",
    "build": "vue-tsc --noEmit && vite build",
    "build:pages": "vue-tsc --noEmit && vite build --base=/Earth-Online-Journal/",
    "check": "npm run typecheck && npm run test:unit && npm run build",
    "deploy": "npm run check && npm run test:pages",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --host 127.0.0.1 --base=/Earth-Online-Journal/",
    "test:pages": "npm run build:pages && node scripts/smoke-pages-preview.mjs",
    "test:unit": "vitest run --environment jsdom",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.1.10"
  }
}
